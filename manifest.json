{
  "manifest_version": 3,
  "name": "WipeX — Auto Delete Tweets",
  "version": "1.3.0",
  "description": "Automatically delete all tweets with smart filters, rate limiting, and backup support.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "scripting", "alarms", "tabs"],
  "host_permissions": ["*://*.x.com/*", "*://*.twitter.com/*"]
}
